# ============================================================
# SuperClaw — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- AI Provider ---
# Options: openai | anthropic | groq | ollama | custom
AI_PROVIDER=openai

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Anthropic API Key (required if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Groq API Key (required if AI_PROVIDER=groq)
GROQ_API_KEY=gsk_...

# Ollama base URL (required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Custom OpenAI-compatible provider (used when AI_PROVIDER=custom)
# Supports any OpenAI-compatible API (OpenRouter, local proxies, etc.)
# Note: Browser User-Agent is automatically set to bypass Cloudflare WAF bot detection
CUSTOM_AI_BASE_URL=https://your-api-endpoint.com/v1
CUSTOM_AI_MODEL=gpt-4o
CUSTOM_AI_API_KEY=your-api-key

# AI Model to use (e.g., gpt-4o, claude-3-5-sonnet-20241022, llama3, mixtral-8x7b-32768)
AI_MODEL=gpt-4o

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC...

# Admin Telegram user ID(s) — comma-separated for multiple admins
# Example: ADMIN_TELEGRAM_ID=123456789,987654321
# Get your ID from @userinfobot on Telegram
ADMIN_TELEGRAM_ID=123456789

# --- WhatsApp ---
# A name for the WhatsApp session (used for session file naming)
WHATSAPP_SESSION_NAME=superclaw

# Admin WhatsApp number(s) — comma-separated for multiple admins
# Example: ADMIN_WHATSAPP_NUMBERS=15551234567@c.us,15559876543@c.us
# Use ADMIN_WHATSAPP_NUMBERS (plural) for multi-admin; ADMIN_WHATSAPP_NUMBER (singular) also supported
ADMIN_WHATSAPP_NUMBER=15551234567@c.us
ADMIN_WHATSAPP_NUMBERS=

# --- Agent Identity ---
# The agent's display name
AGENT_NAME=SuperClaw

# --- VPS Info ---
# Your VPS hostname
VPS_HOSTNAME=my-vps

# --- Logging ---
# Options: error | warn | info | debug
LOG_LEVEL=info

# --- Database ---
# Path to SQLite database file
DB_PATH=./data/superclaw.db

# --- Optional: SerpAPI for web search ---
SERPAPI_KEY=

# --- Optional: Browser Automation (Playwright) ---
# Path to Chromium executable for browser automation
# For Termux: /data/data/com.termux/files/usr/bin/chromium-browser
# For regular systems: leave empty to use Playwright's bundled Chromium
CHROMIUM_PATH=

# Set to 0 to disable Playwright browser downloads (use system Chromium)
PLAYWRIGHT_BROWSERS_PATH=

# --- Optional: Rate limiting ---
MAX_MESSAGES_PER_MINUTE=30
MAX_AI_CALLS_PER_MINUTE=10
MAX_CONCURRENT_TOOLS=5

# --- Sub-agent settings ---
# Maximum number of parallel sub-agent processes (default: 5)
MAX_CONCURRENT_AGENTS=5
# Timeout per sub-agent in milliseconds (default: 600000 = 10 minutes)
SUBAGENT_TIMEOUT_MS=600000
